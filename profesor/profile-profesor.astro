---
// src/pages/profile-profesor.astro

import MainLayout from "../layouts/MainLayout.astro";

const teacher = {
  name: "Profesor Mario Gómez",
  email: "mario.gomez@escuela.edu",
  photo: "https://via.placeholder.com/150",
  videos: [
    {
      title: "Introducción a Álgebra",
      url: "https://www.youtube.com/embed/HEfHFsfGXjs",
    },
    {
      title: "Funciones Cuadráticas",
      url: "https://www.youtube.com/embed/D1vQXKf1uKk",
    },
  ],
};
---

<MainLayout>
  <html lang="es">
    <head>
      <meta charset="UTF-8" />
      <title>Perfil del Maestro - SEAMI</title>
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    </head>

    <body class="dark-mode">
      <!-- Header desde register.astro -->
      <header class="header">
        <a href="/dashboard-profesor" class="logo-container">
          <span class="logo">SEAMI</span>
          <span class="logo-subtitle"
            >SISTEMA EDUCATIVO MULTIMEDIA E INTERACTIVO</span
          >
        </a>

        <div class="actions">
          <!-- Botón de SEAMI ZEN mejorado -->

          <!-- Botón para cambiar tema -->
          <button id="toggle-theme" class="theme-toggle">🌙</button>

          <!-- Botón de perfil con menú desplegable -->
          <div class="profile-dropdown">
            <button id="profile-btn" class="profile-icon">
              <div
                class="avatar-container"
                style="width:40px;height:40px;display:flex;align-items:center;justify-content:center;"
              >
                <img
                  id="profile-avatar"
                  src="/img/avatar_default.webp"
                  alt="Avatar"
                  class="avatar"
                  style="width:35px;height:35px;border-radius:50%;object-fit:cover;border:2px solid #8bc34a;background:#fff;box-shadow:0 0 0 2px #fff;"
                  onerror="this.style.display='none';document.getElementById('avatar-fallback').style.display='flex';"
                />
                <div
                  class="avatar-fallback"
                  id="avatar-fallback"
                  style="display:none;align-items:center;justify-content:center;font-size:1.2rem;font-weight:bold;background:#fff;color:#8bc34a;width:40px;height:40px;border-radius:50%;border:2px solid #8bc34a;box-shadow:0 0 0 2px #fff;position:absolute;top:0;left:0;"
                >
                  --
                </div>
              </div>
            </button>
            <div id="dropdown-menu" class="dropdown-content hidden">
              <a href="/profile-profesor" class="dropdown-item">Ver Perfil</a>
              <a href="/logout" class="dropdown-item">Cerrar Sesión</a>
            </div>
          </div>
        </div>
      </header>

      <main class="profile-container">
        <section class="profile-card">
          <!-- Avatar dinámico igual que en el header, pero en la card -->
          <div
            class="avatar-container"
            style="width:120px;height:120px;display:flex;align-items:center;justify-content:center;margin:auto;position:relative;"
          >
            <img
              id="profile-avatar-card"
              src="/img/avatar_default.webp"
              alt="Foto del Maestro"
              class="profile-img"
              style="width:150px;height:150px;border-radius:50%;object-fit:cover;border:3px solid #8bc34a;background:#fff;box-shadow:0 0 0 2px #fff; "
              onerror="this.style.display='none';document.getElementById('avatar-fallback-card').style.display='flex';"
            />
            <div
              class="avatar-fallback"
              id="avatar-fallback-card"
              style="display:none;align-items:center;justify-content:center;font-size:2.5rem;font-weight:bold;background:#fff;color:#8bc34a;width:150px;height:150px;border-radius:50%;border:3px solid #8bc34a;box-shadow:0 0 0 2px #fff;position:absolute;top:0;left:0; ;"
            >
              --
            </div>
          </div>
          <div style="position: relative; z-index: 1;">
            <h1
              id="profile-name"
              style="font-size: 2rem; font-weight: 700; margin: 1.5rem 0 0.5rem; background: linear-gradient(135deg, #fff 0%, #8bc34a 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
            >
              Profesor Mario Gómez
            </h1>
            <p
              id="profile-email"
              style="font-size: 1rem; color: rgba(255, 255, 255, 0.7); margin-bottom: 2rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem;"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path><polyline points="22,6 12,13 2,6"></polyline></svg
              ><span>mario.gomez@escuela.edu</span>
            </p>
          </div>
          <div class="button-container">
            <a href="/edit-profile-profesor" class="action-btn edit-btn">
              <svg
                class="btn-icon"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"
                ></path>
                <path
                  d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"
                ></path>
              </svg>
              <span>Editar perfil</span>
            </a>
            <a href="/subir_videos" class="action-btn upload-btn">
              <svg
                class="btn-icon"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="17 8 12 3 7 8"></polyline>
                <line x1="12" y1="3" x2="12" y2="15"></line>
              </svg>
              <span>Subir videos</span>
            </a>
           
            
        </section>

        <!-- Mis Videos -->
        <section class="videos-section">
          <h2>Mis Videos</h2>
          <div class="videos-grid" id="videos-grid">
            <div
              id="videos-loading"
              style="text-align:center;width:100%;color:#8bc34a;font-weight:bold;"
            >
              Cargando videos...
            </div>
          </div>
        </section>
      </main>

      <!-- Script principal unificado -->
      <script is:inline>
        document.addEventListener("DOMContentLoaded", async () => {
          // --- Modo oscuro ---
          const toggleBtn = document.getElementById("toggle-theme");
          const body = document.body;
          const header = document.querySelector(".header");

          // Convertir segundos a formato MM:SS o HH:MM:SS
          function formatDuration(seconds) {
            if (!seconds) return '00:00';
            const hours = Math.floor(seconds / 3600);
            const minutes = Math.floor((seconds % 3600) / 60);
            const secs = Math.floor(seconds % 60);
            if (hours > 0) {
              return `${hours}:${minutes.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
            }
            return `${minutes}:${secs.toString().padStart(2, '0')}`;
          }

          function applyTheme(isDark) {
            if (!toggleBtn || !body) return;
            toggleBtn.classList.add("changing");
            body.classList.toggle("light-mode", !isDark);
            if (header) header.classList.toggle("light-mode", !isDark);
            toggleBtn.textContent = isDark ? "🌙" : "☀️";
            localStorage.setItem("theme", isDark ? "dark" : "light");
            setTimeout(() => {
              toggleBtn.classList.remove("changing");
            }, 500);
          }

          // Cargar tema guardado
          const savedTheme = localStorage.getItem("theme");
          if (savedTheme === "light") {
            applyTheme(false);
          } else {
            applyTheme(true);
          }

          // Manejar clic en el botón de tema
          if (toggleBtn) {
            toggleBtn.addEventListener("click", () => {
              const isDark = !body.classList.contains("light-mode");
              applyTheme(!isDark);
            });
          }

          // Dropdown de perfil
          const profileBtn = document.getElementById("profile-btn");
          const dropdownMenu = document.getElementById("dropdown-menu");
          if (profileBtn && dropdownMenu) {
            profileBtn.addEventListener("click", (e) => {
              e.stopPropagation();
              dropdownMenu.classList.toggle("hidden");
            });
            document.addEventListener("click", (event) => {
              if (
                !profileBtn.contains(event.target) &&
                !dropdownMenu.contains(event.target)
              ) {
                dropdownMenu.classList.add("hidden");
              }
            });
          }

          // Botones de acción no requieren lógica especial

          // --- Firebase Auth y datos del usuario ---
          try {
            const { initializeApp } = await import(
              "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js"
            );
            const { getAuth, onAuthStateChanged } = await import(
              "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js"
            );
            const {
              getFirestore,
              doc,
              getDoc,
              collection,
              getDocs,
              query,
              where,
            } = await import(
              "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js"
            );

            const firebaseConfig = {
              apiKey: "AIzaSyBsfou4dclJAJeX-rigz3QHA-mJ0zjh-FI",
              authDomain: "seami-25.firebaseapp.com",
              projectId: "seami-25",
              storageBucket: "seami-25.firebasestorage.app",
              messagingSenderId: "345080770100",
              appId: "1:345080770100:web:cc49649cd2d0bef037a461",
            };

            const app = initializeApp(firebaseConfig);
            const auth = getAuth(app);
            const db = getFirestore(app);

            onAuthStateChanged(auth, async (user) => {
              if (!user) {
                window.location.href = "/login";
                return;
              }

              // Iniciales para fallback
              const initials = user.displayName
                ? user.displayName
                    .split(" ")
                    .map((n) => n[0])
                    .join("")
                    .toUpperCase()
                : user.email
                  ? user.email[0].toUpperCase()
                  : "--";

              const avatarFallback = document.getElementById("avatar-fallback");
              const avatarFallbackCard = document.getElementById(
                "avatar-fallback-card",
              );

              if (avatarFallback) avatarFallback.textContent = initials;
              if (avatarFallbackCard) avatarFallbackCard.textContent = initials;

              try {
                const userDoc = await getDoc(doc(db, "users", user.uid));
                if (userDoc.exists()) {
                  const data = userDoc.data();

                  // Actualizar nombre y email en el perfil
                  const profileName = document.getElementById("profile-name");
                  const profileEmail = document.getElementById("profile-email");

                  if (profileName)
                    profileName.textContent =
                      data.nombre || user.displayName || "Sin nombre";
                  if (profileEmail)
                    profileEmail.textContent = data.email || user.email || "-";

                  // Avatar personalizado si existe
                  if (data.avatarUrl) {
                    // Header avatar
                    const avatarImg = document.getElementById("profile-avatar");
                    if (avatarImg) {
                      avatarImg.src = data.avatarUrl;
                      avatarImg.style.display = "block";
                      if (avatarFallback) avatarFallback.style.display = "none";
                    }

                    // Card avatar
                    const avatarImgCard = document.getElementById(
                      "profile-avatar-card",
                    );
                    if (avatarImgCard) {
                      avatarImgCard.src = data.avatarUrl;
                      avatarImgCard.style.display = "block";
                      if (avatarFallbackCard)
                        avatarFallbackCard.style.display = "none";
                    }
                  } else {
                    // Mostrar fallback si no hay avatar
                    const avatarImg = document.getElementById("profile-avatar");
                    const avatarImgCard = document.getElementById(
                      "profile-avatar-card",
                    );

                    if (avatarImg) avatarImg.style.display = "none";
                    if (avatarImgCard) avatarImgCard.style.display = "none";
                    if (avatarFallback) avatarFallback.style.display = "flex";
                    if (avatarFallbackCard)
                      avatarFallbackCard.style.display = "flex";
                  }

                  // Validaciones de perfil y rol
                  if (!data.perfilCompleto) {
                    window.location.href = "/complete-profile-profesor";
                    return;
                  }
                  if (data.role !== "profesor") {
                    window.location.href = "/dashboard";
                    return;
                  }

                  // --- Cargar videos subidos por el usuario ---
                  const videosGrid = document.getElementById("videos-grid");
                  const loadingDiv = document.getElementById("videos-loading");
                  if (videosGrid) {
                    loadingDiv && (loadingDiv.style.display = "block");
                    videosGrid.innerHTML = loadingDiv
                      ? loadingDiv.outerHTML
                      : "";
                    try {
                      // Buscar videos donde uid == user.uid
                      const q = query(
                        collection(db, "videos"),
                        where("uid", "==", user.uid),
                      );
                      const querySnapshot = await getDocs(q);
                      let html = "";
                      if (querySnapshot.empty) {
                        html =
                          '<div style="color:#fff;text-align:center;width:100%;font-weight:500;">No has subido videos aún.</div>';
                        console.log("No videos found for user:", user.uid);
                      } else {
                        const videos = [];
                        querySnapshot.forEach((doc) => {
                          const v = doc.data();
                          videos.push(v);
                          
                          // Formatear duración
                          let duracion = "";
                          if (v.duration) {
                            if (typeof v.duration === 'string' && v.duration.includes(':')) {
                              duracion = v.duration;
                            } else if (typeof v.duration === 'number') {
                              duracion = formatDuration(v.duration);
                            } else {
                              duracion = v.duration;
                            }
                          }
                          
                          html += `<div class='video-card'>
                            <div style='position:relative;width:100%;height:200px;background:#181c24;border-radius:16px 16px 0 0;overflow:hidden;display:flex;align-items:center;justify-content:center;'>
                              ${v.videoUrl ? `<video src='${v.videoUrl}' controls style='width:100%;height:100%;object-fit:cover;background:#000;'></video>` : `<div style='color:#e57373;'>Sin video</div>`}
                              ${duracion ? `<span style='position:absolute;bottom:10px;right:10px;background:rgba(0,0,0,0.8);color:#8bc34a;font-size:0.85rem;padding:4px 10px;border-radius:6px;font-weight:600;backdrop-filter:blur(10px);'>${duracion}</span>` : ""}
                            </div>
                            <p style='margin:0;padding:1rem 1.2rem;font-weight:600;font-size:1rem;color:#fff;'>${v.title || "Sin título"}</p>
                          </div>`;
                        });
                        console.log("Videos encontrados:", videos);
                      }
                      videosGrid.innerHTML = html;
                    } catch (e) {
                      videosGrid.innerHTML =
                        '<div style="color:#e57373;text-align:center;width:100%;font-weight:500;">Error al cargar tus videos.</div>';
                      console.error("Error al consultar videos:", e);
                    }

                    // --- AGREGAR ESTO PARA MATERIAS ---
                    // Cargar materias
                    const materias = data.materias || [];
                    if (materias.length > 0) {
                      let materiasHtml = `
                        <section class="materias-section">
                          <h2 style="font-size: 1.8rem; font-weight: 700; margin-bottom: 1.5rem; background: linear-gradient(135deg, #8bc34a 0%, #9ccc65 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                            📚 Materias que Imparto
                          </h2>
                          <div class="materias-grid">
                      `;

                      materias.forEach((materia) => {
                        const semestre = materia.semestre || "-";
                        materiasHtml += `
                          <div class="materia-card">
                            <div class="materia-header">
                              <span class="materia-badge">${semestre}° Sem</span>
                            </div>
                            <div class="materia-content">
                              <h3 class="materia-name">${materia.nombre || "Sin nombre"}</h3>
                              <p class="materia-semester">Semestre: <strong>${semestre}</strong></p>
                            </div>
                            <div class="materia-footer">
                              <span class="materia-icon">📖</span>
                            </div>
                          </div>
                        `;
                      });

                      materiasHtml += `
                          </div>
                        </section>
                      `;

                      // Insertar después de videos
                      const videosSection = document.querySelector(".videos-section");
                      if (videosSection) {
                        videosSection.insertAdjacentHTML("afterend", materiasHtml);
                      }
                    } else {
                      // Si no hay materias
                      const noMateriaHtml = `
                        <section class="materias-section">
                          <h2 style="font-size: 1.8rem; font-weight: 700; margin-bottom: 1.5rem;">📚 Materias que Imparto</h2>
                          <div style="text-align: center; padding: 3rem 2rem; background: rgba(255,255,255,0.05); border-radius: 12px; border-left: 4px solid #8bc34a;">
                            <p style="color: rgba(255,255,255,0.7); margin: 0;">No hay materias asignadas aún.</p>
                          </div>
                        </section>
                      `;
                      const videosSection = document.querySelector(".videos-section");
                      if (videosSection) {
                        videosSection.insertAdjacentHTML("afterend", noMateriaHtml);
                      }
                    }

                  }
                } else {
                  window.location.href = "/register";
                  return;
                }
              } catch (e) {
                console.error("Error al cargar datos del usuario:", e);
                window.location.href = "/login";
              }
            });
          } catch (e) {
            console.error("Error al inicializar Firebase:", e);
            window.location.href = "/login";
          }
        });
      </script>

      <style>
        /* Header del register.astro */
        * {
          margin: 0;
          padding: 0;
          box-sizing: border-box;
          font-family: "Segoe UI", sans-serif;
        }

        @keyframes fadeIn {
          from {
            opacity: 0;
            transform: translateY(20px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }

        @keyframes slideIn {
          from {
            opacity: 0;
            transform: translateX(-50px);
          }
          to {
            opacity: 1;
            transform: translateX(0);
          }
        }
        .dark-mode {
          min-height: 100vh;
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: flex-start;
          background: linear-gradient(to right bottom, #0f172a, #3a2443);
          color: white;
          transition: all 0.4s ease;
          animation: fadeIn 0.8s ease-out;
        }

        .dark-mode.light-mode {
          background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);
          color: #0f172a;
        }

        .header {
          position: fixed;
          top: 0;
          width: 100%;
          z-index: 1000;
          display: flex;
          align-items: center;
          justify-content: space-between;
          background-color: rgba(0, 0, 0, 0.6);
          backdrop-filter: blur(10px);
          padding: 0.8rem 2rem;
          transition: all 0.3s ease;
          box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
          animation: fadeInUp 0.8s ease-out;
        }
        .header.light-mode {
          position: fixed;
          top: 0;
          width: 100%;
          z-index: 1000;
          display: flex;
          align-items: center;
          justify-content: space-between;
          background-color: rgba(255, 255, 255, 0.455);
          color: #0f172a;
          backdrop-filter: blur(10px);
          padding: 0.8rem 2rem;
          transition: all 0.3s ease;
          box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
          animation: fadeInUp 0.8s ease-out;
        }
        .actions {
          display: flex;
          align-items: center;
          gap: 1rem;
        }

        .theme-toggle,
        .profile-icon {
          font-size: 1.2rem;
          line-height: 1;
          display: flex;
          align-items: center;
          justify-content: center;
          height: 2.2rem;
          width: 2.2rem;
          padding: 0;
          background: transparent;
          border: none;
          border-radius: 50%;
          color: rgba(100, 181, 246, 0.7);
          transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
          box-shadow: none;
          outline: none;
          opacity: 0.85;
          transform-origin: center;
        }

        .theme-toggle:hover,
        .profile-icon:hover {
          background: rgba(100, 181, 246, 0.08);
          color: rgba(100, 181, 246, 1);
          transform: scale(1.08) rotate(5deg);
          opacity: 1;
        }

        .theme-toggle:active {
          transform: scale(0.95) rotate(-10deg);
          transition: all 0.1s ease;
        }

        @keyframes themeToggleSpin {
          0% {
            transform: rotate(0deg);
          }
          100% {
            transform: rotate(360deg);
          }
        }

        .theme-toggle.changing {
          animation: themeToggleSpin 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .profile-dropdown {
          position: relative;
        }

        .dropdown-content {
          position: absolute;
          right: 0;
          top: 2.5rem;
          background: rgba(255, 255, 255, 0.1);
          min-width: 150px;
          border-radius: 8px;
          box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
          backdrop-filter: blur(10px);
          border: 1px solid rgba(255, 255, 255, 0.15);
          z-index: 1000;
          transition: all 0.4s ease;
        }

        .light-mode .dropdown-content {
          background: rgba(255, 255, 255, 0.98);
          box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
          border: 1px solid rgba(0, 0, 0, 0.08);
        }

        @keyframes fadeInUp {
          from {
            opacity: 0;
            transform: translateY(20px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }

        @media (max-width: 600px) {
          .glass-container {
            padding: 1.5rem;
            margin: 1rem;
          }
          .header {
            padding: 0.6rem 0.8rem;
          }
          .logo {
            font-size: 1.3rem;
          }
          .theme-toggle,
          .profile-icon {
            height: 2rem;
            width: 2rem;
            font-size: 1rem;
          }
          .profile-icon img,
          .avatar-fallback {
            width: 32px !important;
            height: 32px !important;
            font-size: 1rem !important;
          }
        }

        .actions {
          display: flex;
          align-items: center;
          gap: 1rem;
        }

        @keyframes subtitleGlow {
          0%,
          100% {
            text-shadow: 0 0 8px rgba(139, 195, 74, 0.6);
          }
          50% {
            text-shadow:
              0 0 15px rgba(139, 195, 74, 0.9),
              0 0 25px rgba(139, 195, 74, 0.5);
          }
        }
        @keyframes letterSpacing {
          0% {
            letter-spacing: 0px;
          }
          100% {
            letter-spacing: 2px;
          }
        }
        .logo-container {
          display: flex;
          flex-direction: column;
          justify-content: center;
          text-decoration: none;
          cursor: pointer;
          min-height: 40px;
        }
        .logo {
          font-size: 1.7rem;
          font-weight: bold;
          color: #8bc34a;
          transition: all 0.3s ease;
          line-height: 1;
        }
        .logo-subtitle {
          font-size: 0.65rem;
          color: #8bc34a;
          opacity: 0;
          max-height: 0;
          overflow: hidden;
          transform: translateY(-8px) scale(0.9);
          transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
          white-space: nowrap;
          margin-top: 0;
          font-weight: 600;
          letter-spacing: 0px;
          line-height: 1;
        }
        .logo-container:hover .logo {
          color: #9ccc65;
          transform: scale(1.05);
          text-shadow: 0 0 10px rgba(139, 195, 74, 0.3);
        }
        .logo-container:hover .logo-subtitle {
          opacity: 1;
          max-height: 20px;
          margin-top: 0.2rem;
          transform: translateY(0) scale(1);
          animation:
            subtitleGlow 2s ease-in-out infinite,
            letterSpacing 0.4s ease-out forwards;
        }

        .theme-toggle {
          font-size: 1.2rem;
          line-height: 1;
          display: flex;
          align-items: center;
          justify-content: center;
          height: 2.2rem;
          width: 2.2rem;
          padding: 0;
          background: transparent;
          border: none;
          border-radius: 50%;
          color: rgba(100, 181, 246, 0.7);
          transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
          box-shadow: none;
          outline: none;
          opacity: 0.85;
          transform-origin: center;
          cursor: pointer;
        }
        .theme-toggle:hover {
          background: rgba(100, 181, 246, 0.08);
          color: rgba(100, 181, 246, 1);
          transform: scale(1.08) rotate(5deg);
          opacity: 1;
        }
        .theme-toggle:active {
          transform: scale(0.95) rotate(-10deg);
          transition: all 0.1s ease;
        }
        @keyframes themeToggleSpin {
          0% {
            transform: rotate(0deg);
          }
          100% {
            transform: rotate(360deg);
          }
        }
        .theme-toggle.changing {
          animation: themeToggleSpin 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }
        body {
          margin: 0;
          padding-top: 80px;
          font-family: "Segoe UI", sans-serif;
          background: linear-gradient(to right bottom, #0f172a, #3a2443);
          color: white;
          animation: fadeInUp 0.8s ease-out;
          transition: all 0.4s ease;
        }
        body.light-mode {
          background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);
          color: #2d3748;
        }
        .light-mode .header {
          background-color: rgba(255, 255, 255, 0.95);
          color: #0f172a;
          border-bottom: 1px solid #ccc;
          box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        }
        .light-mode .logo {
          color: #8bc34a;
        }
        .light-mode .logo:hover {
          font-weight: bold;
          color: #557c29;
        }

        .light-mode .theme-toggle {
          background: transparent;
          color: #0f172a;
        }
        .light-mode .dropdown-content {
          background: rgba(255, 255, 255, 0.98);
          border: 1px solid rgba(0, 0, 0, 0.08);
          box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
        }
        .light-mode .dropdown-content a {
          color: #2d3748;
        }
        .light-mode .dropdown-content a:hover {
          background-color: rgba(66, 153, 225, 0.1);
          color: #3182ce;
        }

        .profile-container {
          max-width: 1000px;
          margin: auto;
          padding: 2rem;
        }

        .profile-card {
          background: linear-gradient(
            145deg,
            rgba(255, 255, 255, 0.08),
            rgba(255, 255, 255, 0.03)
          );
          backdrop-filter: blur(20px);
          padding: 3rem 2rem;
          border-radius: 24px;
          text-align: center;
          box-shadow:
            0 8px 32px rgba(0, 0, 0, 0.4),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
          border: 1px solid rgba(255, 255, 255, 0.1);
          margin-bottom: 2.5rem;
          animation: fadeInUp 0.8s ease-out 0.2s backwards;
          display: flex;
          flex-direction: column;
          align-items: center;
          position: relative;
          overflow: hidden;
        }

        .profile-card::before {
          content: "";
          position: absolute;
          top: -50%;
          right: -50%;
          width: 200%;
          height: 200%;
          background: radial-gradient(
            circle,
            rgba(139, 195, 74, 0.08) 0%,
            transparent 70%
          );
          animation: pulse 4s ease-in-out infinite;
        }

        @keyframes pulse {
          0%,
          100% {
            transform: scale(1);
            opacity: 0.5;
          }
          50% {
            transform: scale(1.1);
            opacity: 0.8;
          }
        }

        .profile-img {
          width: 150px;
          height: 150px;
          object-fit: cover;
          border-radius: 50%;
          margin-bottom: 1rem;
          border: 4px solid #8bc34a;
          animation:
            fadeInUp 0.8s ease-out 0.4s backwards,
            avatarGlow 3s ease-in-out infinite;
          aspect-ratio: 1/1;
          display: block;
          margin-left: auto;
          margin-right: auto;
          box-shadow:
            0 8px 24px rgba(139, 195, 74, 0.3),
            0 0 0 8px rgba(139, 195, 74, 0.1);
          transition: all 0.4s ease;
        }

        .profile-img:hover {
          transform: scale(1.05);
          box-shadow:
            0 12px 32px rgba(139, 195, 74, 0.5),
            0 0 0 12px rgba(139, 195, 74, 0.15);
        }

        @keyframes avatarGlow {
          0%,
          100% {
            box-shadow:
              0 8px 24px rgba(139, 195, 74, 0.3),
              0 0 0 8px rgba(139, 195, 74, 0.1);
          }
          50% {
            box-shadow:
              0 12px 32px rgba(139, 195, 74, 0.5),
              0 0 0 12px rgba(139, 195, 74, 0.2);
          }
        }

        .button-container {
          display: flex;
          gap: 1.2rem;
          margin-top: 2rem;
          animation: fadeInUp 0.8s ease-out 0.6s backwards;
          position: relative;
          z-index: 1;
          flex-wrap: wrap;
          justify-content: center;
        }

        .action-btn {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          gap: 0.6rem;
          padding: 1rem 2rem;
          border: none;
          font-weight: 600;
          border-radius: 14px;
          text-decoration: none;
          transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
          font-size: 1rem;
          min-width: 180px;
          text-align: center;
          position: relative;
          overflow: hidden;
          cursor: pointer;
        }

        .action-btn::before {
          content: "";
          position: absolute;
          top: 50%;
          left: 50%;
          width: 0;
          height: 0;
          border-radius: 50%;
          background: rgba(255, 255, 255, 0.25);
          transform: translate(-50%, -50%);
          transition:
            width 0.6s,
            height 0.6s;
        }

        .action-btn:hover::before {
          width: 350px;
          height: 350px;
        }

        .btn-icon {
          transition: all 0.3s ease;
          z-index: 1;
        }

        .action-btn span {
          z-index: 1;
        }

        .edit-btn {
          background: linear-gradient(135deg, #8bc34a 0%, #9ccc65 100%);
          color: #0f172a;
          box-shadow:
            0 4px 16px rgba(139, 195, 74, 0.35),
            inset 0 1px 0 rgba(255, 255, 255, 0.2);
        }

        .edit-btn:hover {
          transform: translateY(-4px) scale(1.02);
          box-shadow:
            0 8px 28px rgba(139, 195, 74, 0.5),
            inset 0 1px 0 rgba(255, 255, 255, 0.3);
        }

        .edit-btn:hover .btn-icon {
          transform: rotate(-15deg) scale(1.1);
        }

        .edit-btn:active {
          transform: translateY(-2px) scale(0.98);
        }

        .upload-btn {
          background: linear-gradient(135deg, #42a5f5 0%, #64b5f6 100%);
          color: #fff;
          box-shadow:
            0 4px 16px rgba(66, 165, 245, 0.35),
            inset 0 1px 0 rgba(255, 255, 255, 0.2);
        }

        .upload-btn:hover {
          transform: translateY(-4px) scale(1.02);
          box-shadow:
            0 8px 28px rgba(66, 165, 245, 0.5),
            inset 0 1px 0 rgba(255, 255, 255, 0.3);
        }

        .upload-btn:hover .btn-icon {
          transform: translateY(-3px) scale(1.1);
        }

        .upload-btn:active {
          transform: translateY(-2px) scale(0.98);
        }

        .videos-section {
          animation: fadeInUp 0.8s ease-out 0.8s backwards;
        }

        .videos-section h2 {
          margin-bottom: 2rem;
          text-align: center;
          font-size: 2rem;
          font-weight: 700;
          background: linear-gradient(135deg, #8bc34a 0%, #9ccc65 100%);
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          background-clip: text;
          position: relative;
          padding-bottom: 1rem;
        }

        .videos-section h2::after {
          content: "";
          position: absolute;
          bottom: 0;
          left: 50%;
          transform: translateX(-50%);
          width: 80px;
          height: 4px;
          background: linear-gradient(90deg, transparent, #8bc34a, transparent);
          border-radius: 2px;
        }

        .videos-grid {
          display: grid;
          grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
          gap: 2rem;
        }

        .video-card {
          background: linear-gradient(
            145deg,
            rgba(255, 255, 255, 0.08),
            rgba(255, 255, 255, 0.03)
          );
          border-radius: 16px;
          overflow: hidden;
          padding: 0;
          box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
          text-align: left;
          animation: fadeInUp 0.8s ease-out backwards;
          transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
          border: 1px solid rgba(255, 255, 255, 0.1);
          backdrop-filter: blur(10px);
        }

        .video-card:hover {
          transform: translateY(-8px);
          box-shadow:
            0 12px 32px rgba(139, 195, 74, 0.2),
            0 0 0 1px rgba(139, 195, 74, 0.3);
        }

        .video-card:nth-child(1) {
          animation-delay: 1s;
        }
        .video-card:nth-child(2) {
          animation-delay: 1.2s;
        }

        .video-card p {
          margin: 0;
          padding: 1rem 1.2rem;
          font-weight: 600;
          font-size: 1rem;
          color: #fff;
        }

        @media (max-width: 600px) {
          .profile-card,
          .videos-section {
            padding: 1rem;
          }

          .video-card iframe {
            height: 180px;
          }

          .button-container {
            flex-direction: column;
            gap: 1rem;
            width: 100%;
          }

          .action-btn {
            width: 100%;
            min-width: unset;
            padding: 0.9rem 1.5rem;
          }
        }

        .profile-dropdown {
          position: relative;
        }

        .profile-icon {
          background: transparent;
          border: none;
          font-size: 1.2rem;
          color: white;
          cursor: pointer;
        }

        .dropdown-content {
          position: absolute;
          right: 0;
          top: 2.5rem;
          background: rgba(255, 255, 255, 0.1);
          min-width: 150px;
          border-radius: 8px;
          box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
          backdrop-filter: blur(10px);
          border: 1px solid rgba(255, 255, 255, 0.15);
          z-index: 1000;
        }

        .dropdown-content.hidden {
          display: none;
        }

        .dropdown-content a {
          color: white;
          padding: 0.75rem 1rem;
          text-decoration: none;
          display: block;
          transition: background 0.3s ease;
        }

        .dropdown-content a:hover {
          background-color: rgba(255, 255, 255, 0.1);
        }

        .profile-card .avatar-container {
          width: 150px;
          height: 150px;
          display: flex;
          align-items: center;
          justify-content: center;
          margin: 0 auto 1rem auto;
          position: relative;
          z-index: 1;
        }
        .profile-card .profile-img,
        .profile-card .avatar-fallback {
          width: 150px;
          height: 150px;
          border-radius: 50%;
          object-fit: cover;
          border: 4px solid #8bc34a;
          background: #fff;
          box-shadow:
            0 8px 24px rgba(139, 195, 74, 0.3),
            0 0 0 8px rgba(139, 195, 74, 0.1);
          display: flex;
          align-items: center;
          justify-content: center;
          margin-bottom: 0;
        }
        .profile-card .avatar-fallback {
          font-size: 3rem;
          font-weight: bold;
          color: #8bc34a;
          position: absolute;
          top: 0;
          left: 0;
        }

        /* Estilos para modo claro - botones de acción */
        .light-mode .edit-btn {
          color: #0f172a;
          box-shadow:
            0 4px 16px rgba(139, 195, 74, 0.25),
            inset 0 1px 0 rgba(255, 255, 255, 0.4);
        }

        .light-mode .edit-btn:hover {
          box-shadow:
            0 8px 28px rgba(139, 195, 74, 0.45),
            inset 0 1px 0 rgba(255, 255, 255, 0.5);
        }

        .light-mode .upload-btn {
          color: #fff;
          box-shadow:
            0 4px 16px rgba(66, 165, 245, 0.25),
            inset 0 1px 0 rgba(255, 255, 255, 0.3);
        }

        .light-mode .upload-btn:hover {
          box-shadow:
            0 8px 28px rgba(66, 165, 245, 0.45),
            inset 0 1px 0 rgba(255, 255, 255, 0.4);
        }

        /* Estilos de Materias */
        .materias-section {
          animation: fadeInUp 0.8s ease-out 1s backwards;
          margin-bottom: 3rem;
        }

        .materias-grid {
          display: grid;
          grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
          gap: 1.5rem;
          padding: 2rem 0;
        }

        .materia-card {
          background: linear-gradient(
            145deg,
            rgba(139, 195, 74, 0.15),
            rgba(139, 195, 74, 0.05)
          );
          border: 2px solid rgba(139, 195, 74, 0.3);
          border-radius: 16px;
          padding: 1.5rem;
          transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
          cursor: pointer;
          position: relative;
          overflow: hidden;
        }

        .materia-card::before {
          content: "";
          position: absolute;
          top: 0;
          left: -100%;
          width: 100%;
          height: 100%;
          background: linear-gradient(
            90deg,
            transparent,
            rgba(139, 195, 74, 0.1),
            transparent
          );
          transition: left 0.5s ease;
        }

        .materia-card:hover {
          transform: translateY(-8px) scale(1.02);
          border-color: rgba(139, 195, 74, 0.6);
          box-shadow: 0 12px 32px rgba(139, 195, 74, 0.3);
          background: linear-gradient(
            145deg,
            rgba(139, 195, 74, 0.25),
            rgba(139, 195, 74, 0.1)
          );
        }

        .materia-card:hover::before {
          left: 100%;
        }

        .materia-header {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin-bottom: 1rem;
          padding-bottom: 1rem;
          border-bottom: 1px solid rgba(139, 195, 74, 0.2);
        }

        .materia-badge {
          background: linear-gradient(135deg, #8bc34a, #9ccc65);
          color: #0f172a;
          padding: 0.4rem 0.8rem;
          border-radius: 8px;
          font-size: 0.75rem;
          font-weight: 700;
          text-transform: uppercase;
          letter-spacing: 0.5px;
        }

        .materia-content {
          margin-bottom: 1.2rem;
        }

        .materia-name {
          font-size: 1.3rem;
          font-weight: 700;
          color: #fff;
          margin: 0 0 0.5rem 0;
          line-height: 1.3;
          word-break: break-word;
        }

        .materia-semester {
          font-size: 0.9rem;
          color: rgba(255, 255, 255, 0.7);
          margin: 0;
          display: flex;
          align-items: center;
          gap: 0.5rem;
        }

        .materia-semester strong {
          color: #8bc34a;
          font-weight: 700;
        }

        .materia-footer {
          display: flex;
          justify-content: flex-end;
          padding-top: 1rem;
          border-top: 1px solid rgba(139, 195, 74, 0.2);
        }

        .materia-icon {
          font-size: 1.8rem;
          transition: transform 0.3s ease;
        }

        .materia-card:hover .materia-icon {
          transform: scale(1.2) rotate(-10deg);
        }

        /* Modo claro */
        .light-mode .materia-card {
          background: linear-gradient(
            145deg,
            rgba(139, 195, 74, 0.08),
            rgba(139, 195, 74, 0.02)
          );
          border-color: rgba(139, 195, 74, 0.2);
        }

        .light-mode .materia-card:hover {
          background: linear-gradient(
            145deg,
            rgba(139, 195, 74, 0.15),
            rgba(139, 195, 74, 0.08)
          );
          border-color: rgba(139, 195, 74, 0.4);
          box-shadow: 0 12px 32px rgba(139, 195, 74, 0.15);
        }

        .light-mode .materia-name {
          color: #0f172a;
        }

        .light-mode .materia-semester {
          color: rgba(15, 23, 42, 0.6);
        }

        .light-mode .materia-header {
          border-bottom-color: rgba(139, 195, 74, 0.1);
        }

        .light-mode .materia-footer {
          border-top-color: rgba(139, 195, 74, 0.1);
        }

        @media (max-width: 768px) {
          .materias-grid {
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1rem;
          }

          .materia-card {
            padding: 1rem;
          }

          .materia-name {
            font-size: 1.1rem;
          }
        }
      </style>
    </body>
